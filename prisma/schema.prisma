// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  deviceFp     String?
  licenseKey   String?
  banned       Boolean  @default(false)
  lastActive   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AppSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LicenseKey {
  id            String    @id @default(cuid())
  key           String    @unique
  label         String?
  status        String    @default("active") // active, suspended, expired, used
  plan          String    @default("monthly") // trial, weekly, monthly, lifetime
  maxDevices    Int       @default(1)
  deviceFp      String?
  boundAt       DateTime?
  expiresAt     DateTime?
  usageCount    Int       @default(0)
  lastUsedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model ActivityLog {
  id        String   @id @default(cuid())
  type      String   // key_verify, login, team_gen, device_bind, admin_action, error, transfer
  message   String
  licenseKey String?
  deviceFp  String?
  ip        String?
  createdAt DateTime @default(now())
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  message   String
  target    String   @default("all") // all, premium, selected
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}
