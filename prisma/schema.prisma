// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://neondb_owner:npg_mrf5YU9VgBbe@ep-wandering-sound-auc3pst8-pooler.c-10.us-east-1.aws.neon.tech/neondb?sslmode=require"
}

model LicenseKey {
  id            String    @id @default(cuid())
  key           String    @unique
  label         String?
  status        String    @default("active")
  plan          String    @default("monthly")
  maxDevices    Int       @default(1)
  deviceFp      String?
  boundAt       DateTime?
  expiresAt     DateTime?
  usageCount    Int       @default(0)
  lastUsedAt    DateTime?
  createdBy     String?   @default("admin")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status])
  @@index([plan])
  @@index([deviceFp])
}

model Device {
  id           String   @id @default(cuid())
  deviceId     String   @unique
  licenseKey   String?
  plan         String?
  boundAt      DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([licenseKey])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  deviceFp     String?
  licenseKey   String?
  banned       Boolean  @default(false)
  lastActive   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Subscription {
  id            String    @id @default(cuid())
  licenseKey    String    @unique
  plan          String    @default("free")
  status        String    @default("active")
  features      String
  deviceId      String?
  expiresAt     DateTime?
  activatedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status])
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model JwtToken {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdminLog {
  id         String   @id @default(cuid())
  type       String
  message    String
  licenseKey String?
  deviceFp   String?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([type])
  @@index([createdAt])
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  message   String
  target    String   @default("all")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}
