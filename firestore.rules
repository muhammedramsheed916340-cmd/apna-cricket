rules_version = '2';

// ====== Apna Cricket — Firestore Security Rules ======
// Copy these rules to: Firebase Console → Firestore Database → Rules → Paste → Publish
//
// Collections (all defined in src/lib/firestore-collections.ts):
//   licenses         — License keys (activation, plan, device binding)
//   subscriptions    — Active subscriptions (plan, features, expiry)
//   devices          — Device registrations (deviceId, bound license)
//   users            — User profiles (email, name, licenseKey)
//   free_offer_keys  — Free offer keys (validity, maxUsers, activations)
//   settings         — App settings (jwt_token, admin config)
//   admin_data       — Admin-only data (logs, announcements)

service cloud.firestore {
  match /databases/{database}/documents {

    // ====== licenses collection ======
    // Document ID = license key (e.g. "RMSMT-GSDC-7KFW-326N")
    // Fields: key, plan, status, deviceFp, expiresAt, boundAt, activatedAt, usageCount, lastUsedAt, appVersion, createdAt
    match /licenses/{licenseKey} {
      // Allow read for license verification (client reads to check status)
      // Allow write only from server-side API routes (no direct client writes)
      allow read: if true;
      allow write: if true; // TODO: tighten with Firebase Auth when available
    }

    // ====== subscriptions collection ======
    // Document ID = subscription ID (auto or license key)
    // Fields: plan, features, status, expiresAt, deviceId, activatedAt
    match /subscriptions/{subscriptionId} {
      allow read: if true;
      allow write: if true; // TODO: tighten with Firebase Auth
    }

    // ====== devices collection ======
    // Document ID = device fingerprint
    // Fields: deviceId, licenseKey, plan, boundAt, createdAt
    match /devices/{deviceId} {
      allow read: if true;
      allow write: if true; // TODO: tighten with Firebase Auth
    }

    // ====== users collection ======
    // Document ID = user ID (Firebase Auth UID)
    // Fields: email, name, licenseKey, plan, createdAt
    match /users/{userId} {
      allow read: if true;
      allow write: if true; // TODO: tighten: request.auth.uid == userId
    }

    // ====== free_offer_keys collection ======
    // Document ID = free offer key (e.g. "FREE-24H-ABCD-XYZ1")
    // Fields: key, enabled, validityHours, maxUsers, activationCount, createdAt, expiryDate, activatedDevices[]
    match /free_offer_keys/{keyId} {
      allow read: if true;
      allow write: if true; // Admin-only via API
    }

    // ====== settings collection ======
    // Document ID = setting key (e.g. "jwt_token", "admin_password")
    // Fields: key, value, updatedAt
    match /settings/{settingKey} {
      // Settings contain sensitive data (JWT, admin config) — restrict reads
      // Only server-side API routes with admin auth should access
      allow read: if true; // TODO: tighten with admin auth
      allow write: if true; // TODO: tighten with admin auth
    }

    // ====== admin_data collection ======
    // Document ID = admin action ID
    // Fields: type, message, metadata, createdAt
    match /admin_data/{adminId} {
      allow read: if false; // Admin-only
      allow write: if false; // Server-only via Admin SDK
    }

    // ====== Default deny ======
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
